        "form_content": {
          "title": "Ground speed",
          "label": "Ground speed (m/s)",
          "logItem": "GPS[0].Spd",
          "scaleFactor": 1,
          "time": 30,
          "color": "#000000",
          "periodS": 30
        },
        "about": {
          "name": "Graph",
          "info": "Graph example built using the Sandbox widget. User customizable plot options."
        },
        "sandbox": "// Include plotly\nconst script = document.createElement(\"script\")\nscript.src = \"https://cdn.plot.ly/plotly-2.35.0.min.js\"\ndocument.body.appendChild(script)\n\n// Setup layout\nconst plot_layout = { \n    title: { text: options.title },\n    legend: { itemclick: false, itemdoubleclick: false }, \n    margin: { b: 50, l: 65, r: 50, t: 50 },\n    xaxis: { title: { text: \"time (s)\" }, range: [-options.time, options.time], zeroline: false, showline: true, mirror: true },\n    yaxis: { title: { text: options.label }, zeroline: false, showline: true, mirror: true }\n}\n\nconst plot_data = [\n    { mode: 'lines', x: [], y:[], line: { color: options.color } }\n]\n\ndata = {\n    time: [],\n    value: []\n}\n\nlet plot_created = false\n\n// Update plot\nlet lastTime\nfunction update_data(time) {\n    lastTime = time\n\n    if (logData.time == null) {\n        return\n    }\n\n    // Update plot\n    plot_data[0].x = array_offset(logData.time, -lastTime)\n    plot_data[0].y = logData.value\n\n    // Make sure plotly is loaded\n    if (window.Plotly !== undefined) {\n        if (!plot_created) {\n            replot()\n        }\n        Plotly.redraw(div)\n    }\n}\n\n\nfunction replot() {\n    // Clear plot and redraw to cope with change in size or options\n    plot_layout.title.text = options.title\n    plot_layout.xaxis.range[0] = -options.time\n    plot_layout.yaxis.title.text = options.label\n    plot_data[0].line.color = options.color\n\n    if (window.Plotly !== undefined) {\n        Plotly.purge(div)\n        Plotly.newPlot(div, plot_data, plot_layout, {displaylogo: false})\n        plot_created = true\n    }\n}\n\n// Watch for size changes\nnew ResizeObserver(() => { replot() }).observe(div)\n\n// Varbles to hold data\nconst logData = {\n    log: null,\n    time: null,\n    value: null\n}\n\n// Load function\nloadLog = function (newLog) {\n    logData.log = newLog\n    if (options.logItem == null || logData.log == null) {\n        return\n    }\n\n    const match = options.logItem.match(/^(\\w+)(?:\\[(\\d+)\\])?\\.(\\w+)$/);\n    const name = match[1]\n    const instance = match[2]\n    const field = match[3]\n\n    let timeUS\n    let value\n\n    if (instance != null) {\n        const instanceNum = parseInt(instance)\n        timeUS = logData.log.get_instance(name, instanceNum, \"TimeUS\")\n        value = logData.log.get_instance(name, instanceNum, field)\n    } else {\n        timeUS = logData.log.get(name, \"TimeUS\")\n        value = logData.log.get(name, field)\n    }\n\n    if (timeUS == null || value == null) {\n        throw new Error(`Unknown log message: ${options.logItem}`)\n    }\n\n    logData.time = array_scale(timeUS, 1/1000000)\n    logData.value = array_scale(value, options.scaleFactor)\n\n    update_data(lastTime)\n}\n\n// Runtime function\nsetTime = function(time) {\n    update_data(time)\n}\n\n// Optional function to allow run-time update of options\nhandle_options = function (new_options) {\n    options = new_options\n    loadLog(logData.log)\n    update_data(lastTime)\n\n    replot()\n}\n"
      }
    },
    "1": {
      "x": "1",
      "y": "0",
      "w": "1",
      "h": "1",
      "type": "WidgetSandBoxVideoOverlay",
      "options": {
        "form": {
          "components": []
        },
        "form_content": {},
        "about": {
          "name": "Attitude gauge",
          "info": "Attitude gauge example built using the Sandbox widget. Reads ATT log message."
        },
        "sandbox": "// Import Gauges from https://github.com/teocci/js-module-flight-indicators\n// Add ccs with link tag\nconst ccs = document.createElement('link')\nccs.rel = \"stylesheet\"\nccs.href = \"https://unpkg.com/flight-indicators-js@1.0.5/css/flight-indicators.css\"\ndocument.body.appendChild(ccs)\n\nlet attitude\nimport(\"https://unpkg.com/flight-indicators-js@1.0.5/esm/module-flight-indicators.mjs\").then((mod) => {\n    const FlightIndicators = mod.default\n\n    attitude = new FlightIndicators(\n        div,\n        FlightIndicators.TYPE_ATTITUDE\n    )\n\n    // This is a dirty hack to switch to remote copy's of images\n    let images = div.querySelectorAll(\"img\")\n    for (const image of images) {\n        let src = image.src\n\n        var lastIndex = src.lastIndexOf(\"/img/\")\n        image.src = \"https://unpkg.com/flight-indicators-js@1.0.5\" + src.substr(lastIndex)\n\n        // Hide box is broken, hide manually\n        // see: https://github.com/teocci/js-module-flight-indicators/pull/1\n        if (src.endsWith(\"fi_box.svg\")) {\n            image.style.display = \"none\"\n        }\n    }\n\n    resize()\n})\n\n// Remove margin and border to give more room\ndiv.style.margin = 0\ndiv.style.border = 0\ndiv.style.background = \"none\"\ndiv.style.padding = 0\n\n// Center gauge\ndiv.style.display = \"flex\"\ndiv.style.justifyContent = \"center\"\ndiv.style.alignItems = \"center\"\n\nfunction resize() {\n\n    if (attitude == null) {\n        return\n    }\n\n    // Get width and height of widget\n    const width = div.offsetWidth\n    const height = div.offsetHeight\n\n    const max_size = Math.min(width, height)\n    attitude.resize(max_size)\n\n    setTime(lastTime)\n}\n\n// Watch for size changes\nnew ResizeObserver(() => { resize() }).observe(div)\n\nlet logData = {\n    time: null,\n    roll: null,\n    pitch: null,\n}\n\n// Load function\nloadLog = function (log) {\n    const ATT = log.get(\"ATT\")\n    logData.time = array_scale(ATT.TimeUS, 1/1000000)\n    logData.roll = ATT.Roll\n    logData.pitch = ATT.Pitch\n\n    setTime(lastTime)\n}\n\n// Runtime function\nlet lastTime\nsetTime = function(time) {\n\n    if (time == null) {\n        return\n    }\n    lastTime = time\n\n\n    if (logData.time == null || logData.roll == null || logData.pitch == null) {\n        return\n    }\n\n    if (attitude == null) {\n        return\n    }\n\n    const roll = linear_interp(logData.roll, logData.time, time)\n    const pitch = linear_interp(logData.pitch, logData.time, time)\n\n    // Roll is backwards for some reason...\n    attitude.updateRoll(-roll)\n    attitude.updatePitch(pitch)\n}\n"
      }
    },
